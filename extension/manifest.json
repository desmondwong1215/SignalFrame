{
  "manifest_version": 3,
  "name": "SignalFrame",
  "version": "0.1.0",
  "description": "Warns when social content appears likely AI-generated.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://m.youtube.com/*",
    "https://www.facebook.com/*",
    "https://facebook.com/*",
    "https://m.facebook.com/*",
    "https://www.x.com/*",
    "https://x.com/*",
    "https://www.twitter.com/*",
    "https://twitter.com/*",
    "https://m.twitter.com/*",
    "https://www.tiktok.com/*",
    "https://tiktok.com/*",
    "https://m.tiktok.com/*",
    "https://www.instagram.com/*",
    "https://instagram.com/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://m.youtube.com/*",
        "https://www.facebook.com/*",
        "https://facebook.com/*",
        "https://m.facebook.com/*",
        "https://www.x.com/*",
        "https://x.com/*",
        "https://www.twitter.com/*",
        "https://twitter.com/*",
        "https://m.twitter.com/*",
        "https://www.tiktok.com/*",
        "https://tiktok.com/*",
        "https://m.tiktok.com/*",
        "https://www.instagram.com/*",
        "https://instagram.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "incognito": "split"
}